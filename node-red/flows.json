    {
        "id": "fn-format-alert",
        "type": "function",
        "z": "tab-motor-monitor",
        "name": "Format Alert Status",
        "func": "let status = msg.payload.status;\nlet color = \"green\";\nif (status === \"WARNING\") color = \"orange\";\nif (status === \"CRITICAL\") color = \"red\";\nmsg.payload = `<span style=\"color:${color}; font-size:24px; font-weight:bold;\">${status}</span>`;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 280,
        "wires": [["ui-text-alert-status"]]
    },
    {
        "id": "ui-text-alert-status",
        "type": "ui-text",
        "z": "tab-motor-monitor",
        "group": "ui-group-temp",
        "order": 3,
        "width": 5,
        "height": 0,
        "name": "Alert Status",
        "label": "Alert Status",
        "format": "{{msg.payload}}",
        "layout": "row-center",
        "style": false,
        "font": "",
        "fontSize": 16,
        "color": "#717171",
        "wrapText": false,
