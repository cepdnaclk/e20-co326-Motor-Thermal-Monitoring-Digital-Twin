        "id": "influxdb-out",
        "type": "influxdb out",
        "z": "tab-motor-monitor",
        "influxdb": "influxdb-config",
        "name": "Write to InfluxDB",
        "measurement": "motor_thermal_v2",
        "precision": "ms",
        "retentionPolicy": "",
        "database": "database",
        "precisionV18FluxV20": "ms",
        "retentionPolicyV18Flux": "",
        "org": "co326",
        "bucket": "motor_health",
        "x": 650,
        "y": 440,
        "wires": []
