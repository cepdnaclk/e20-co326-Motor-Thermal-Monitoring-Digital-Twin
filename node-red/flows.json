    {
        "id": "fn-influx-prep",
        "type": "function",
        "z": "tab-motor-monitor",
        "name": "Prep InfluxDB Write",
        "func": "// Write alert data to InfluxDB measurement 'motor_thermal_v2'\n// This keeps the Grafana digital twin dashboard updated.\nvar p = msg.payload;\nvar statusNum = p.status === \"CRITICAL\" ? 2 : p.status === \"WARNING\" ? 1 : 0;\nmsg.payload = [\n    {\n        measurement: \"motor_thermal_v2\",\n        tags: { group: \"group10\", project: \"motorTemp\" },\n        fields: {\n            temperature:  p.temperature,\n            z_score:      p.z_score,\n            status_code:  statusNum,\n            fan_command:  p.fan_command === \"ON\" ? 1 : 0\n        },\n        timestamp: new Date()\n    }\n];\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 440,
        "wires": [["influxdb-out"]]
    },
