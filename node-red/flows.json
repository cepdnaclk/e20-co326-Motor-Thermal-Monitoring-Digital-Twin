    {
        "id": "fn-format-log",
        "type": "function",
        "z": "tab-motor-monitor",
        "name": "Format Alert Log",
        "func": "let log = context.get(\"log\") || [];\nlet status = msg.payload.status;\nlet temp = msg.payload.temperature.toFixed(2);\nlet z = msg.payload.z_score.toFixed(2);\nlet time = new Date().toLocaleTimeString();\nlet entry = `[${time}] ${status} — ${temp}°C (z: ${z})`;\nlog.unshift(entry);\nif (log.length > 10) log = log.slice(0, 10);\ncontext.set(\"log\", log);\nmsg.payload = log.join(\"<br>\");\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 360,
        "wires": [["ui-text-alert-log"]]
    },
    {
        "id": "ui-text-alert-log",
        "type": "ui-text",
        "z": "tab-motor-monitor",
