    {
        "id": "805db8c56aeb7032",
        "type": "function",
        "z": "c5c81a027e273d61",
        "name": "Format Log",
        "func": "let log = context.get(\"log\") || [];\n\nlet status = msg.payload.status;\nlet temp = msg.payload.temperature.toFixed(2);\nlet z = msg.payload.z_score.toFixed(2);\nlet time = new Date().toLocaleTimeString();\n\nlet entry = `[${time}] ${status} — ${temp}°C (z: ${z})`;\nlog.unshift(entry);\nif (log.length > 10) log = log.slice(0, 10);\n\ncontext.set(\"log\", log);\nmsg.payload = log.join(\"<br>\");\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
