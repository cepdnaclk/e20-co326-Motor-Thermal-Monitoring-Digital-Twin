    {
        "id": "7a71ed3cb2dd964a",
        "type": "ui-template",
        "z": "c5c81a027e273d61",
        "group": "de82038b11b60ab8",
        "page": "",
        "ui": "",
        "name": "Fan Status",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n  <div style=\"display:flex; flex-direction:column; align-items:center; justify-content:center; padding:16px;\">\n    <svg :class=\"isOn ? 'spinning' : ''\" width=\"80\" height=\"80\" viewBox=\"0 0 100 100\">\n      <ellipse cx=\"50\" cy=\"25\" rx=\"10\" ry=\"24\" fill=\"#42a5f5\" opacity=\"0.85\" transform=\"rotate(0 50 50)\"/>\n      <ellipse cx=\"50\" cy=\"25\" rx=\"10\" ry=\"24\" fill=\"#42a5f5\" opacity=\"0.85\" transform=\"rotate(60 50 50)\"/>\n      <ellipse cx=\"50\" cy=\"25\" rx=\"10\" ry=\"24\" fill=\"#42a5f5\" opacity=\"0.85\" transform=\"rotate(120 50 50)\"/>\n      <ellipse cx=\"50\" cy=\"25\" rx=\"10\" ry=\"24\" fill=\"#42a5f5\" opacity=\"0.85\" transform=\"rotate(180 50 50)\"/>\n      <ellipse cx=\"50\" cy=\"25\" rx=\"10\" ry=\"24\" fill=\"#42a5f5\" opacity=\"0.85\" transform=\"rotate(240 50 50)\"/>\n      <ellipse cx=\"50\" cy=\"25\" rx=\"10\" ry=\"24\" fill=\"#42a5f5\" opacity=\"0.85\" transform=\"rotate(300 50 50)\"/>\n      <circle cx=\"50\" cy=\"50\" r=\"8\" fill=\"#1565c0\"/>\n      <circle cx=\"50\" cy=\"50\" r=\"4\" fill=\"#90caf9\"/>\n    </svg>\n    <span :style=\"{marginTop: '8px', fontSize: '16px', fontWeight: 'bold', color: isOn ? '#00c853' : '#999'}\">\n      {{ isOn ? 'FAN ON' : 'FAN OFF' }}\n    </span>\n  </div>\n</template>\n\n<script>\nexport default {\n  props: ['msg'],\n  computed: {\n    isOn() {\n      return this.msg && this.msg.payload === 'ON';\n    }\n  }\n}\n</script>\n\n<style>\n.spinning {\n  display: inline-block;\n  animation: spin 0.8s linear infinite;\n}\n@keyframes spin {\n  from { transform: rotate(0deg); }\n  to { transform: rotate(360deg); }\n}\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 710,
